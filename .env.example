# Glintvex email configuration
# Copy this file to ".env" and fill in to send real emails + calendar invites.
# Without SMTP_URL, every notification is still saved to data/outbox.log and the
# raw submissions are always persisted to data/leads.json / subscribers.json / bookings.json.

# Inbox that receives lead, subscriber, and booking notifications (YOUR inbox):
MAIL_TO=you@yourdomain.com

# The "From" address shown on outgoing mail (and the .ics organizer):
MAIL_FROM=no-reply@glintvex.com

# SMTP connection string. Leave blank to log-only. Examples:
#   Gmail (app password):   smtps://you@gmail.com:app-password@smtp.gmail.com:465
#   Mailgun:                smtp://postmaster@your.domain:password@smtp.mailgun.org:587
#   SendGrid:               smtps://apikey:SG.xxxxx@smtp.sendgrid.net:465
SMTP_URL=

# Optional: port the server listens on (default 8099)
# PORT=8099
